# Required: API key from your Resend account dashboard
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# Optional sender address used by /api/contact
# - For initial testing (no domain verification): onboarding@resend.dev
# - For production/custom sender: contact@yourdomain.com (after verifying your domain in Resend)
CONTACT_FROM_EMAIL=onboarding@resend.dev
